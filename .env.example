# Database (PostgreSQL)
# For production: set DATABASE_URL to your PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/cavemo-repair

# Server URL (for API calls from frontend)
VITE_SERVER_URL=http://localhost:3000

# JWT Secret (generate a strong random string for production)
JWT_SECRET=change-this-to-a-strong-secret-in-production

# Firebase (optional - only if using Firebase features)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-auth-domain
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
